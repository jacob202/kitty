# Copy to kitty_gateway/openwebui.env and edit as needed.
# This file is sourced by start_openwebui.sh before defaults are applied.

# Data and identity
OPENWEBUI_VENV="$HOME/kitty-services/venv"
LITELLM_VENV="$HOME/kitty-services/venv-litellm"
OPENWEBUI_DATA_DIR="$HOME/kitty-services/open-webui-data"
OPENWEBUI_SECRET_FILE="$HOME/kitty-services/open-webui-data/.webui_secret"
WEBUI_NAME="Kitty WebUI"
WEBUI_URL="http://127.0.0.1:3000"

# Model gateway
OPENAI_API_BASE_URL="http://127.0.0.1:8001/v1"
OPENAI_API_KEY="kitty-local-key-change-me"
# Multi-endpoint provider list (semicolon-delimited). Keep LiteLLM first.
# Example with pipelines server:
# OPENAI_API_BASE_URLS="http://127.0.0.1:8001/v1;http://127.0.0.1:9099"
# OPENAI_API_KEYS="kitty-local-key-change-me;pipelines-local-key"
OPENAI_API_BASE_URLS="http://127.0.0.1:8001/v1"
OPENAI_API_KEYS="kitty-local-key-change-me"
DEFAULT_MODELS="kitty-default"
DEFAULT_PINNED_MODELS="kitty-default,kitty-private,kitty-agent,kitty-smart"
ENABLE_OPENAI_API="true"
ENABLE_OLLAMA_API="false"
ENABLE_DIRECT_CONNECTIONS="false"

# Local-first behavior
OFFLINE_MODE="true"
ENABLE_VERSION_UPDATE_CHECK="false"

# Logging and security defaults
GLOBAL_LOG_LEVEL="WARNING"
ENABLE_PROFILE_IMAGE_URL_FORWARDING="false"
ENABLE_USER_WEBHOOKS="false"

# LiteLLM budget + auth (consumed by start_litellm.sh)
LITELLM_MASTER_KEY="kitty-local-key-change-me"
LITELLM_MAX_BUDGET_USD="2.00"

# Admin bootstrap (set once for first launch, then optional to remove)
WEBUI_ADMIN_NAME="Jacob"
WEBUI_ADMIN_EMAIL="jacob@example.com"
WEBUI_ADMIN_PASSWORD="change-this-now"
ENABLE_SIGNUP="false"
ENABLE_LOGIN_FORM="true"
ENABLE_API_KEYS="true"
SHOW_ADMIN_DETAILS="false"

# Interface defaults for task-oriented workflows
DEFAULT_USER_ROLE="user"
DEFAULT_PROMPT_SUGGESTIONS='[
  {"title":["Plan a feature","with constraints"],"content":"Turn this brain dump into a scoped technical contract with non-goals, tests, and acceptance criteria."},
  {"title":["Implement from spec","safely"],"content":"Implement this spec in small commits, run tests after each step, and report files changed plus risks."},
  {"title":["Debug failing tests","fast"],"content":"Find root cause of this failing test, patch minimally, rerun target tests, then summarize what changed and why."},
  {"title":["Refactor for clarity","without regressions"],"content":"Refactor this module for readability and maintainability while preserving behavior; include before/after risks and test proof."},
  {"title":["Review my plan","as CTO"],"content":"Critique this plan for hidden assumptions, complexity risk, and cheaper/better alternatives before execution."},
  {"title":["Daily standup","for continuity"],"content":"Summarize current repo state, recent changes, open risks, and next 3 highest-value actions."}
]'

# Web search defaults (Tavily recommended when key exists in .env)
ENABLE_WEB_SEARCH="true"
WEB_SEARCH_ENGINE="tavily"
ENABLE_SEARCH_QUERY_GENERATION="true"
WEB_SEARCH_RESULT_COUNT="5"
WEB_SEARCH_CONCURRENT_REQUESTS="2"
WEB_SEARCH_DOMAIN_FILTER_LIST=""
BRAVE_SEARCH_API_KEY="${BRAVE_SEARCH_API_KEY:-}"
TAVILY_API_KEY="${TAVILY_API_KEY:-}"
SEARXNG_QUERY_URL=""

# Image generation defaults (OpenAI-compatible endpoint via LiteLLM/OpenRouter)
ENABLE_IMAGE_GENERATION="true"
ENABLE_IMAGE_PROMPT_GENERATION="true"
IMAGE_GENERATION_ENGINE="openai"
IMAGE_GENERATION_MODEL="openrouter/google/gemini-2.5-flash-image"
IMAGE_SIZE="1024x1024"
IMAGE_STEPS="4"
IMAGES_OPENAI_API_BASE_URL="http://127.0.0.1:8001/v1"
IMAGES_OPENAI_API_KEY="kitty-local-key-change-me"

# Code execution defaults (requires a reachable Jupyter service)
ENABLE_CODE_EXECUTION="true"
CODE_EXECUTION_ENGINE="jupyter"
CODE_EXECUTION_JUPYTER_URL="http://127.0.0.1:8888"
CODE_EXECUTION_JUPYTER_AUTH="token"
CODE_EXECUTION_JUPYTER_AUTH_TOKEN=""
CODE_EXECUTION_JUPYTER_TIMEOUT="60"

# Code interpreter defaults
ENABLE_CODE_INTERPRETER="true"
CODE_INTERPRETER_ENGINE="jupyter"
CODE_INTERPRETER_JUPYTER_URL="http://127.0.0.1:8888"
CODE_INTERPRETER_JUPYTER_AUTH="token"
CODE_INTERPRETER_JUPYTER_AUTH_TOKEN=""
CODE_INTERPRETER_JUPYTER_TIMEOUT="60"

# Extensibility: Tool Servers (OpenAPI + MCP streamable-http)
TOOL_SERVER_CONNECTIONS='[]'
AIOHTTP_CLIENT_TIMEOUT_TOOL_SERVER="30"
AIOHTTP_CLIENT_TIMEOUT_TOOL_SERVER_DATA="15"
AIOHTTP_CLIENT_SESSION_TOOL_SERVER_SSL="true"

# Extensibility: Open Terminal server connection(s)
OPEN_TERMINAL_URL="http://127.0.0.1:9614"
OPEN_TERMINAL_API_KEY="change-me-open-terminal-key"
TERMINAL_SERVER_CONNECTIONS="[{\"id\":\"open-terminal-local\",\"name\":\"OpenTerminal Local\",\"enabled\":true,\"url\":\"${OPEN_TERMINAL_URL}\",\"path\":\"/openapi.json\",\"auth_type\":\"bearer\",\"key\":\"${OPEN_TERMINAL_API_KEY}\"}]"

# Set to 1 for launcher smoke-check only (no server start)
# OPENWEBUI_SMOKE="1"

# Optional public HTTPS tunnel via Cloudflare (off by default)
ENABLE_CLOUDFLARE_HTTPS="0"
CF_TUNNEL_TARGET_URL="http://127.0.0.1:3000"
CF_TUNNEL_MODE="quick"
CF_TUNNEL_TOKEN="${CF_TUNNEL_TOKEN:-}"
CF_TUNNEL_TOKEN_FILE="${CF_TUNNEL_TOKEN_FILE:-}"
