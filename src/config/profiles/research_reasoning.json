{
  "name": "research_reasoning",
  "description": "Deep analysis and thorough investigation - for complex research tasks",
  "version": "1.0",
  "created_at": "2024-01-01T00:00:00",
  "updated_at": "2024-01-01T00:00:00",
  "model": {
    "provider": "claude",
    "model_name": "claude-3-5-sonnet",
    "temperature": 0.3,
    "max_tokens": 8000,
    "top_p": 0.9,
    "frequency_penalty": 0.1,
    "presence_penalty": 0.1,
    "timeout": 180
  },
  "system_prompt": "You are a research assistant specializing in thorough investigation. Approach every query with academic rigor. Cite sources when possible. Provide comprehensive analysis with multiple perspectives. Always verify facts and note uncertainties. Structure your responses with clear sections: Executive Summary, Detailed Analysis, Supporting Evidence, and Conclusions/Recommendations.",
  "personality": "analytical",
  "thinking_style": "step-by-step",
  "response_format": "structured",
  "tools": {
    "web_search": true,
    "code_execution": false,
    "file_operations": true,
    "schematic_analysis": false,
    "bom_manager": false,
    "datasheet_lookup": true,
    "vision_analysis": false,
    "vector_search": true,
    "memory_recall": true,
    "custom_agents": true
  },
  "middleware": {
    "auto_route": true,
    "cost_threshold_local": 0.0,
    "cost_threshold_flash": 0.01,
    "cost_threshold_heavy": 0.05,
    "prefer_local_for_simple": false,
    "prefer_flash_for_vision": true,
    "prefer_heavy_for_coding": true,
    "max_cost_per_request": 0.15
  },
  "ui_theme": "research",
  "animation_speed": "slow",
  "compact_mode": false,
  "features": {
    "deep_research": true,
    "source_verification": true,
    "multi_step_analysis": true,
    "citation_tracking": true,
    "cross_reference_validation": true
  }
}
