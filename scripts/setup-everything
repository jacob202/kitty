#!/usr/bin/env bash
# Setup Everything - One command to rule them all
# Usage: setup-everything

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}╔══════════════════════════════════════╗"
echo "║   Kitty Orca IDE - Complete Setup   ║"
echo "╚══════════════════════════════════════╝${NC}"
echo ""

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.."
SCRIPTS_DIR="$ROOT_DIR/scripts"

# 1. Make all scripts executable
echo -e "${YELLOW}Step 1/6: Setting up scripts...${NC}"
chmod +x "$SCRIPTS_DIR"/*
echo -e "${GREEN}✓${NC} Scripts executable"

# 2. Install Git hooks
echo -e "${YELLOW}Step 2/6: Installing Git hooks...${NC}"
"$SCRIPTS_DIR/install-git-hooks"
echo -e "${GREEN}✓${NC} Git hooks installed"

# 3. Verify Ghostty config
echo -e "${YELLOW}Step 3/6: Verifying Ghostty config...${NC}"
if [[ -f ~/.config/ghostty/config ]]; then
    echo -e "${GREEN}✓${NC} Ghostty config exists"
else
    echo -e "${RED}✗${NC} Ghostty config not found"
fi

# 4. Verify Yazi config
echo -e "${YELLOW}Step 4/6: Verifying Yazi config...${NC}"
if [[ -f ~/.config/yazi/config.toml ]]; then
    echo -e "${GREEN}✓${NC} Yazi config exists"
else
    echo -e "${YELLOW}!${NC} Yazi config not found (optional)"
fi

# 5. Test context files
echo -e "${YELLOW}Step 5/6: Testing context files...${NC}"
CONTEXT_FILES=(
    "~/NOW.md"
    "~/AGENT_CONTEXT.md"
    "~/SKILLS.md"
    "~/PARKING_LOT.md"
    "~/Projects/kitty/docs/STANDUP.md"
    "~/Projects/kitty/docs/CONTEXT_ENGINEERING.md"
)

for file in "${CONTEXT_FILES[@]}"; do
    path=$(eval echo "$file")
    if [[ -f "$path" ]]; then
        echo -e "${GREEN}✓${NC} $file"
    else
        echo -e "${YELLOW}!${NC} $file (missing)"
    fi
done

# 6. Final verification
echo -e "${YELLOW}Step 6/6: Running verification...${NC}"
"$SCRIPTS_DIR/verify-context-setup" 2>&1 | tail -5

echo ""
echo -e "${GREEN}╔══════════════════════════════════════╗"
echo "║          Setup Complete!            ║"
echo "╚══════════════════════════════════════╝${NC}"
echo ""
echo "Quick start:"
echo "  1. Open Ghostty (or reload: ghostty +reload)"
echo "  2. Run: terminal-pane"
echo "  3. Select agent: agent-selector claude"
echo "  4. Create task: coordinator \"my first task\""
echo ""
echo "Emergency:"
echo "  - Panic button: panic-button"
echo "  - Status check: coordinator status"
echo ""
