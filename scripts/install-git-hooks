#!/usr/bin/env bash
# Install Git hooks for auto-close functionality
# Usage: install-git-hooks

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.."
GIT_HOOKS_DIR="$ROOT_DIR/.git/hooks"
SCRIPTS_DIR="$ROOT_DIR/scripts"

echo "Installing Git hooks..."

# Ensure hooks directory exists
mkdir -p "$GIT_HOOKS_DIR"

# Create post-commit hook
cat > "$GIT_HOOKS_DIR/post-commit" << 'EOF'
#!/usr/bin/env bash
# Auto-close task on commit
# Automatically closes coordinator tasks when commit message matches task ID

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.."
COORDINATOR_SCRIPT="$ROOT_DIR/scripts/coordinator"

# Get last commit message
COMMIT_MSG=$(git log -1 --pretty=%B)
COMMIT_HASH=$(git rev-parse --short HEAD)

# Extract task ID (patterns: TASK-123, #123, [123])
TASK_ID=""
if [[ "$COMMIT_MSG" =~ TASK-([0-9]+) ]]; then
    TASK_ID="TASK-${BASH_REMATCH[1]}"
elif [[ "$COMMIT_MSG" =~ \#([0-9]+) ]]; then
    TASK_ID="#${BASH_REMATCH[1]}"
elif [[ "$COMMIT_MSG" =~ \[([0-9]+)\] ]]; then
    TASK_ID="#${BASH_REMATCH[1]}"
fi

if [[ -n "$TASK_ID" ]] && [[ -x "$COORDINATOR_SCRIPT" ]]; then
    echo "📝 Auto-closing task: $TASK_ID"
    "$COORDINATOR_SCRIPT" close "$TASK_ID" "Committed in $COMMIT_HASH" 2>/dev/null || true
fi
EOF

chmod +x "$GIT_HOOKS_DIR/post-commit"

echo "✓ Installed post-commit hook"
echo ""
echo "Git hooks installed successfully!"
echo ""
echo "Test it:"
echo "  1. Create a task: coordinator \"test task\""
echo "  2. Commit with task ID: git commit -m \"Fix bug #123\""
echo "  3. Task should auto-close"
