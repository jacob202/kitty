#!/usr/bin/env python3
"""
Context Injector for Agent Spawns

Auto-injects canonical context files when spawning any agent.
Ensures agents always start with full context.

Usage:
    inject-context --agent claude --task "build feature X"
    inject-context --agent gemini --file ~/Projects/kitty/AGENTS.md
"""

import argparse
import sys
from pathlib import Path

CONTEXT_FILES = [
    "~/NOW.md",
    "~/AGENT_CONTEXT.md", 
    "~/SKILLS.md",
    "~/PARKING_LOT.md",
    "~/Projects/kitty/SESSION_HANDOFF.md",
    "~/Projects/kitty/CURRENT_FOCUS.md",
    "~/Projects/kitty/docs/STANDUP.md",
    "~/Projects/kitty/docs/CONTEXT_ENGINEERING.md",
]

def expand_path(path_str):
    """Expand ~ and return Path."""
    return Path(path_str).expanduser()

def load_context():
    """Load all canonical context files."""
    context_parts = []
    
    for path_str in CONTEXT_FILES:
        path = expand_path(path_str)
        if path.exists():
            content = path.read_text(encoding="utf-8")
            context_parts.append(f"### {path_str}\n{content}")
        else:
            context_parts.append(f"### {path_str}\n[File not found]")
    
    return "\n\n---\n\n".join(context_parts)

def build_prompt(agent, task, mode="plan"):
    """Build the full prompt with context injection."""
    
    context = load_context()
    
    active_agent_file = Path.home() / ".kitty_active_agent"
    active_agent = "claude"
    if active_agent_file.exists():
        active_agent = active_agent_file.read_text().strip()
    
    prompt = f"""# Agent Coordination Request

**Active Agent:** {active_agent}
**Target Agent:** {agent}
**Mode:** {mode}
**Task:** {task}

---

## Context Engineering (Read First)

{context}

---

## Instructions

You are in **PLAN MODE**. Do not execute code yet.

1. **Read the context files** above, especially:
   - `~/NOW.md` - Current goal
   - `~/AGENT_CONTEXT.md` - Machine map
   - `~/SKILLS.md` - Coaching rules
   - `docs/STANDUP.md` - Operating rules (HOOK_START...HOOK_END)

2. **Understand the task**: {task}

3. **Break into subtasks** and identify which agent should handle each:
   - Code work → Claude, Codex, Opencode
   - Research → Gemini
   - Reasoning → Qwen

4. **Post tasks** to the coordinator queue (don't execute yet)

5. **Wait for approval** before executing any code.

---

## Output Format

```
## Plan Summary
[Brief description]

## Subtasks
1. [Task] → [Agent]
2. [Task] → [Agent]

## Next Action
[What should happen first]
```
"""
    return prompt

def main():
    parser = argparse.ArgumentParser(description="Inject context into agent spawns")
    parser.add_argument("--agent", required=True, help="Target agent (claude, gemini, etc.)")
    parser.add_argument("--task", required=True, help="Task description")
    parser.add_argument("--mode", default="plan", choices=["plan", "execute"], help="Mode")
    parser.add_argument("--output", help="Output file (optional)")
    
    args = parser.parse_args()
    
    prompt = build_prompt(args.agent, args.task, args.mode)
    
    if args.output:
        Path(args.output).write_text(prompt, encoding="utf-8")
        print(f"Prompt saved to: {args.output}")
    else:
        print(prompt)

if __name__ == "__main__":
    main()
