#!/usr/bin/env bash
# Panic Button - Emergency reset for agent chaos
# Usage: panic-button [--force]
#
# Kills all running agents, clears context, resets to clean state

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${RED}🚨 PANIC BUTTON ACTIVATED${NC}"
echo ""

# Confirm unless --force
if [[ "${1:-}" != "--force" ]]; then
    echo -n "This will kill all agents and reset context. Continue? [y/N] "
    read -r response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi
fi

echo "Step 1/5: Killing agent processes..."
# Kill common agent processes
pkill -f "claude" 2>/dev/null || true
pkill -f "gemini" 2>/dev/null || true
pkill -f "codex" 2>/dev/null || true
pkill -f "opencode" 2>/dev/null || true
pkill -f "node.*agent" 2>/dev/null || true
pkill -f "python.*agent" 2>/dev/null || true
echo -e "${GREEN}✓${NC} Agent processes killed"

echo "Step 2/5: Clearing active agent..."
rm -f ~/.kitty_active_agent
rm -f ~/.kitty_coordinator/tasks/*.md 2>/dev/null || true
echo -e "${GREEN}✓${NC} Active agent cleared"

echo "Step 3/5: Clearing temporary context..."
rm -f /tmp/yazi_chosen 2>/dev/null || true
rm -rf /tmp/kitty_* 2>/dev/null || true
echo -e "${GREEN}✓${NC} Temporary files cleared"

echo "Step 4/5: Resetting terminal state..."
if command -v reset &> /dev/null; then
    reset || true
fi
echo -e "${GREEN}✓${NC} Terminal reset"

echo "Step 5/5: Cleaning coordinator queue..."
if [[ -f ~/Projects/kitty/data/coordinator_queue.json ]]; then
    echo "[]" > ~/Projects/kitty/data/coordinator_queue.json
    echo -e "${GREEN}✓${NC} Coordinator queue cleared"
else
    echo "ℹ️  No coordinator queue found"
fi

echo ""
echo -e "${GREEN}🚨 Panic reset complete!${NC}"
echo ""
echo "Next steps:"
echo "  1. Select agent: agent-selector"
echo "  2. Check status: coordinator status"
echo "  3. Start fresh: terminal-pane"
echo ""
