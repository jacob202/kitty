#!/usr/bin/env bash
# Auto-close task on git commit
# Add to .git/hooks/post-commit
#
# Automatically closes coordinator tasks when commit message matches task ID

set -euo pipefail

COORDINATOR_SCRIPT="$(dirname "${BASH_SOURCE[0]}")/coordinator"

# Get last commit message
COMMIT_MSG=$(git log -1 --pretty=%B)
COMMIT_HASH=$(git rev-parse --short HEAD)

# Extract task ID from commit message (e.g., "TASK-123" or "#123")
TASK_ID=$(echo "$COMMIT_MSG" | grep -oE '(TASK-[0-9]+|#[0-9]+)' | head -1)

if [[ -n "$TASK_ID" ]]; then
    echo "📝 Auto-closing task: $TASK_ID"
    
    # Use coordinator to close task
    if [[ -x "$COORDINATOR_SCRIPT" ]]; then
        "$COORDINATOR_SCRIPT" close "$TASK_ID" "Auto-closed: committed in $COMMIT_HASH"
        echo "✅ Task $TASKID closed"
    else
        echo "⚠️  Coordinator script not found: $COORDINATOR_SCRIPT"
    fi
else
    echo "ℹ️  No task ID found in commit message"
fi
