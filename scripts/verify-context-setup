#!/usr/bin/env bash
# Verify context engineering setup
# Usage: verify-context-setup

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

check_file() {
  if [[ -f "$1" ]]; then
    echo -e "${GREEN}✓${NC} $1"
    return 0
  else
    echo -e "${RED}✗${NC} $1 (missing)"
    return 1
  fi
}

check_executable() {
  if [[ -x "$1" ]]; then
    echo -e "${GREEN}✓${NC} $1 (executable)"
    return 0
  else
    echo -e "${YELLOW}!${NC} $1 (not executable)"
    return 1
  fi
}

echo "=== Machine-Level Context Files ==="
check_file ~/NOW.md
check_file ~/AGENT_CONTEXT.md
check_file ~/SKILLS.md
check_file ~/PARKING_LOT.md

echo ""
echo "=== Project Context Files ==="
check_file ~/Projects/kitty/SESSION_HANDOFF.md
check_file ~/Projects/kitty/CURRENT_FOCUS.md
check_file ~/Projects/kitty/docs/STANDUP.md
check_file ~/Projects/kitty/docs/CONTEXT_ENGINEERING.md

echo ""
echo "=== Hook Infrastructure ==="
check_file ~/.claude/settings.json
check_file ~/Projects/kitty/.cursor/hooks.json
check_file ~/.config/opencode/opencode.json
check_file ~/.config/opencode/plugins/kitty-hook.js
check_file ~/.codex/agent-start.sh
check_file ~/.gemini/hooks/session-start.sh

echo ""
echo "=== Scripts ==="
check_executable ~/Projects/kitty/scripts/session-start
check_executable ~/Projects/kitty/scripts/session-handoff
check_executable ~/Projects/kitty/.cursor/hooks/session-stop.sh

echo ""
echo "=== Hook Content Verification ==="

# Check STANDUP.md has HOOK markers
if grep -q "HOOK_START" ~/Projects/kitty/docs/STANDUP.md && grep -q "HOOK_END" ~/Projects/kitty/docs/STANDUP.md; then
  echo -e "${GREEN}✓${NC} STANDUP.md has HOOK_START/HOOK_END markers"
else
  echo -e "${RED}✗${NC} STANDUP.md missing HOOK markers"
fi

# Check session-start script exists
if command -v session-start &> /dev/null || [[ -f ~/Projects/kitty/scripts/session-start ]]; then
  echo -e "${GREEN}✓${NC} session-start available"
else
  echo -e "${YELLOW}!${NC} session-start not in PATH (use full path)"
fi

echo ""
echo "=== Next Steps ==="
echo "1. Test each agent to verify context injection"
echo "2. Run: session-start --full (manual verification)"
echo "3. Run: session-handoff --print (test handoff generation)"
