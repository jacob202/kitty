#!/usr/bin/env python3
"""
Kitty Coordinator Agent

A master agent that:
1. Reads user intent ("build feature X")
2. Breaks into tasks
3. Spawns specialist agents (Claude, Gemini, Codex, etc.)
4. Tracks progress in task_boundaries.jsonl
5. Posts to Kanban automatically

Usage:
    coordinator "build feature X" --plan
    coordinator "review PR #42" --assign claude
    coordinator status
"""

import argparse
import json
import sys
from pathlib import Path
from datetime import datetime

# Import Kitty's task boundary system
sys.path.insert(0, str(Path(__file__).parent.parent))
from gateway.task_boundary import task_boundary

COORDINATOR_DATA = Path.home() / ".kitty_coordinator"
ACTIVE_AGENT_FILE = Path.home() / ".kitty_active_agent"

AGENT_CONFIGS = {
    "claude": {
        "type": "code",
        "mode": "plan",
        "context": ["~/Projects/kitty/AGENTS.md", "~/Projects/kitty/docs/STANDUP.md"],
        "expensive": True,
    },
    "gemini": {
        "type": "research",
        "mode": "plan",
        "context": ["~/Projects/kitty/AGENTS.md"],
        "expensive": False,
    },
    "codex": {
        "type": "code",
        "mode": "plan",
        "context": ["~/Projects/kitty/AGENTS.md"],
        "expensive": False,
    },
    "opencode": {
        "type": "code",
        "mode": "plan",
        "context": ["~/Projects/kitty/AGENTS.md"],
        "expensive": False,
    },
    "qwen": {
        "type": "reasoning",
        "mode": "plan",
        "context": ["~/Projects/kitty/AGENTS.md"],
        "expensive": False,
    },
}

def get_active_agent():
    """Get currently active agent from file."""
    if ACTIVE_AGENT_FILE.exists():
        return ACTIVE_AGENT_FILE.read_text().strip()
    return "claude"  # Default

def set_active_agent(agent_name):
    """Set the active agent."""
    if agent_name not in AGENT_CONFIGS:
        print(f"Unknown agent: {agent_name}")
        print(f"Available: {', '.join(AGENT_CONFIGS.keys())}")
        return False
    ACTIVE_AGENT_FILE.write_text(agent_name)
    print(f"Active agent set to: {agent_name}")
    return True

def create_task(description, parent_task=None):
    """Create a new task in the task boundary system."""
    import uuid
    task_id = f"task-{str(uuid.uuid4())[:8]}"
    name = description.split(":")[0] if ":" in description else "Task"
    task_boundary.open(task_id, name, description)
    print(f"Created task: {task_id} - {description}")
    return task_id

def spawn_agent(agent_name, task_description, mode="plan"):
    """Spawn an agent for a specific task."""
    if agent_name not in AGENT_CONFIGS:
        print(f"Unknown agent: {agent_name}")
        return False
    
    config = AGENT_CONFIGS[agent_name]
    
    # Create task
    task_id = create_task(task_description)
    
    # Build context injection
    context_files = config.get("context", [])
    context_text = ""
    for cf in context_files:
        cf_path = Path(cf.replace("~", str(Path.home())))
        if cf_path.exists():
            context_text += f"\n--- Context: {cf} ---\n"
            context_text += cf_path.read_text()[:5000]  # First 5KB
    
    # Build agent instructions
    instructions = f"""
# Task: {task_description}
# Agent: {agent_name}
# Mode: {mode}
# Context Engineering:
- Read ~/NOW.md first
- Read ~/AGENT_CONTEXT.md for machine map
- Read ~/SKILLS.md for coaching rules
- Follow docs/CONTEXT_ENGINEERING.md
- Auto-inject from docs/STANDUP.md (HOOK_START...HOOK_END)

{context_text}

## Instructions
You are in PLAN MODE. Do not execute code yet.
1. Understand the task
2. Break into subtasks
3. Identify which agent should handle each subtask
4. Post tasks to coordinator queue
"""
    
    # Save task instructions
    task_file = COORDINATOR_DATA / "tasks" / f"{task_id}.md"
    task_file.parent.mkdir(parents=True, exist_ok=True)
    task_file.write_text(instructions)
    
    print(f"Spawned {agent_name} for task: {task_id}")
    print(f"Task file: {task_file}")
    
    return task_id

def status():
    """Show current coordinator status."""
    print("=== Kitty Coordinator Status ===")
    print(f"Active Agent: {get_active_agent()}")
    print(f"Data Dir: {COORDINATOR_DATA}")
    
    # Show recent tasks
    tasks_dir = COORDINATOR_DATA / "tasks"
    if tasks_dir.exists():
        recent = list(tasks_dir.glob("*.md"))[-5:]
        print(f"\nRecent tasks ({len(recent)}):")
        for t in recent:
            print(f"  - {t.stem}")
    else:
        print("\nNo tasks yet")

def main():
    parser = argparse.ArgumentParser(description="Kitty Coordinator Agent")
    parser.add_argument("task", nargs="?", help="Task description")
    parser.add_argument("--plan", action="store_true", help="Plan mode (default)")
    parser.add_argument("--assign", type=str, help="Assign to specific agent")
    parser.add_argument("--agent", type=str, help="Set active agent")
    parser.add_argument("--status", action="store_true", help="Show status")
    
    args = parser.parse_args()
    
    # Initialize
    COORDINATOR_DATA.mkdir(parents=True, exist_ok=True)
    
    if args.status:
        status()
        return
    
    if args.agent:
        set_active_agent(args.agent)
        return
    
    if args.task:
        agent = args.assign or get_active_agent()
        spawn_agent(agent, args.task, mode="plan" if args.plan else "execute")
        return
    
    # No args = show status
    status()

if __name__ == "__main__":
    main()
