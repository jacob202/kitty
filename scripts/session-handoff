#!/usr/bin/env bash
# Session handoff generator
# Usage: session-handoff [--save] [--print]
#
# Generates a handoff summary from the current session state.
# Called automatically on session end or manually when requested.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.."
HANDOFF_FILE="$ROOT_DIR/docs/handoffs/HANDOFF-$(date +%Y-%m-%d).md"
CURRENT_HANDOFF="$ROOT_DIR/SESSION_HANDOFF.md"

# Ensure handoffs directory exists
mkdir -p "$ROOT_DIR/docs/handoffs"

# Generate handoff content
generate_handoff() {
    local git_status
    local test_result
    local git_branch
    
    git_branch=$(git -C "$ROOT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
    git_status=$(git -C "$ROOT_DIR" status --short 2>/dev/null | head -20 || echo "  (git not available)")
    
    echo "## Session Handoff — $(date +%Y-%m-%d)"
    echo ""
    echo "**Branch:** $git_branch"
    echo "**Time:** $(date '+%Y-%m-%d %H:%M')"
    echo ""
    echo "## Files Changed This Session"
    echo ""
    echo "\`\`\`"
    echo "$git_status"
    echo "\`\`\`"
    echo ""
    echo "## Test Status"
    echo ""
    echo "\`\`\`bash"
    echo "# Run: cd $ROOT_DIR && python -m pytest tests/ -q --tb=short"
    echo "\`\`\`"
    echo ""
    echo "## Open Work"
    echo ""
    echo "- [ ] "
    echo ""
    echo "## Next Actions"
    echo ""
    echo "1. "
    echo ""
}

# Save handoff to dated file
save_handoff() {
    generate_handoff > "$HANDOFF_FILE"
    echo "Handoff saved to: $HANDOFF_FILE"
}

# Update current handoff
update_current() {
    generate_handoff > "$CURRENT_HANDOFF"
    echo "Current handoff updated: $CURRENT_HANDOFF"
}

# Main logic
case "${1:-}" in
    --save)
        save_handoff
        update_current
        ;;
    --print)
        generate_handoff
        ;;
    *)
        # Default: update current handoff
        update_current
        ;;
esac
