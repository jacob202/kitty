{
  "description": "MLX optimization settings for Kitty models",
  "quantization": {
    "default_bits": 4,
    "compute_dtype": "float16",
    "lazy_load": true,
    "stream_and_offload": true
  },
  "lora_config": {
    "enabled": true,
    "rank": 8,
    "scale": 10.0,
    "layers": 16,
    "learning_rate": 1e-4,
    "batch_size": 2,
    "iters": 200,
    "mask_prompt": true,
    "adapter_path": "./adapters"
  },
  "model_configs": {
    "default": {
      "model": "mlx-community/Qwen3.5-4B-4bit",
      "use_fp16": true,
      "lazy_imports": true
    },
    "general": {
      "model": "mlx-community/Llama-3.2-3B-Instruct-4bit",
      "use_fp16": false
    },
    "conversation": {
      "model": "mlx-community/Llama-3.2-3B-Instruct-4bit",
      "use_fp16": false
    },
    "routing": {
      "model": "mlx-community/DeepSeek-R1-Distill-Qwen-1.5B-4bit",
      "use_fp16": false,
      "always_loaded": true
    }
  },
  "memory_optimization": {
    "clear_cache_every_n_tokens": 100,
    "offload_threshold_gb": 12,
    "prefetch_models": ["routing"]
  },
  "performance": {
    "stream_chunk_size": 512,
    "prefetch_next_token": true,
    "compile_for_speed": true
  }
}