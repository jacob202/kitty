# Hermes Agent Environment Configuration
# Copy this file to `.env` locally and fill in only the keys you need.
# Keep real secrets out of git.

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_DEVICE_KEY=
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
# For legacy Moonshot keys, override KIMI_BASE_URL with:
#   https://api.moonshot.ai/v1
# For Moonshot China keys, override KIMI_BASE_URL with:
#   https://api.moonshot.cn/v1
KIMI_CN_API_KEY=
ARCEEAI_API_KEY=
ARCEE_BASE_URL=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_CN_API_KEY=
MINIMAX_CN_BASE_URL=https://api.minimaxi.com/v1
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_GO_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
HF_TOKEN=
HERMES_QWEN_BASE_URL=https://portal.qwen.ai/v1
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
XAI_API_KEY=
NVIDIA_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
MISTRAL_ORG_ID=
ALIBABA_API_KEY=
ALIBABA_ACCESS_KEY=
ALIBABA_SECRET_KEY=
HERMES_API_KEY=
OPENROUTER_MANAGEMENT_KEY=
CHARBOT_OPENROUTER_KEY=
CURSOR_API_KEY=
NGROK_API_KEY=
CEREBRAS_API_KEY=
BFL_API_KEY=
JULES_API_KEY=
AGENTROUTER_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=
BRAVE_SEARCH_API_KEY=
SEARXNG_QUERY_URL=

# -----------------------------------------------------------------------------
# Tool keys
# -----------------------------------------------------------------------------
EXA_API_KEY=
PARALLEL_API_KEY=
FIRECRAWL_API_KEY=
FAL_KEY=
HONCHO_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=deepseek-ai/deepseek-v4-pro
KITTY_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
USE_OPENROUTER=true
LITELLM_BASE=http://localhost:8001
LITELLM_KEY=kitty-local-key-change-me
LITELLM_MASTER_KEY=kitty-local-key-change-me
LITELLM_MAX_BUDGET_USD=2.00
LITELLM_API_KEY=kitty-local-key-change-me
KITTY_WEBUI_ORIGIN=
VOICE_TOOLS_OPENAI_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# Terminal / execution
# -----------------------------------------------------------------------------
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
TERMINAL_DOCKER_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_SINGULARITY_IMAGE=docker://nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_CWD=
TERMINAL_SSH_HOST=
TERMINAL_SSH_USER=
TERMINAL_SSH_PORT=22
TERMINAL_SSH_KEY=
HERMES_DOCKER_BINARY=

# -----------------------------------------------------------------------------
# Optional sudo
# -----------------------------------------------------------------------------
SUDO_PASSWORD=

# -----------------------------------------------------------------------------
# Browser / automation
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# -----------------------------------------------------------------------------
# Messaging / collaboration
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_HOME_CHANNEL_NAME=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PORT=8443
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_ENABLED=false
WHATSAPP_ALLOWED_USERS=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_POLL_INTERVAL=15
EMAIL_ALLOWED_USERS=
EMAIL_HOME_ADDRESS=
GATEWAY_ALLOW_ALL_USERS=false

# -----------------------------------------------------------------------------
# Voice and pacing
# -----------------------------------------------------------------------------
HERMES_HUMAN_DELAY_MODE=off
HERMES_HUMAN_DELAY_MIN_MS=800
HERMES_HUMAN_DELAY_MAX_MS=2500
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false

# -----------------------------------------------------------------------------
# Context compression
# -----------------------------------------------------------------------------
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_THRESHOLD=0.85
# LLM_MODEL is kept for reference only — Hermes reads model.default from ~/.hermes/config.yaml.
# LLM_MODEL=anthropic/claude-opus-4.6

# -----------------------------------------------------------------------------
# Reinforcement learning / evaluation
# -----------------------------------------------------------------------------
TINKER_API_KEY=
WANDB_API_KEY=
RL_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Skills hub / GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=

# -----------------------------------------------------------------------------
# STT / speech-to-text
# -----------------------------------------------------------------------------
STT_GROQ_MODEL=whisper-large-v3-turbo
STT_OPENAI_MODEL=whisper-1
GROQ_BASE_URL=https://api.groq.com/openai/v1
STT_OPENAI_BASE_URL=https://api.openai.com/v1
