{
  "sessionStart": "python3.11 -m pytest tests/ -q --tb=line 2>/dev/null | tail -1 || true",
  "autoSave": true,
  "terminalIntegration": true,
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run test)",
      "Bash(npx tsc --noEmit)",
      "Bash(git fetch *)",
      "Bash(python3* -m pytest*)",
      "Bash(uv *)",
      "Bash(gh *)",
      "Bash(cat ~/.claude/*)"
    ],
    "deny": [
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(npm publish*)",
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scan-secrets.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scan-secrets.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/warn-large-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify.sh"
          },
          {
            "type": "command",
            "command": "if [[ \"${CLAUDE_FILE_PATH:-}\" == *.py ]] && command -v ruff &>/dev/null; then ruff check --quiet \"$CLAUDE_FILE_PATH\" 2>&1 | head -20 || true; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/preflight.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/recall-thread.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-stop.sh"
          }
        ]
      }
    ]
  }
}
