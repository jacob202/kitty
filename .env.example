# Copy to `.env` in the project root. Never `git commit` this file.
# I cannot read Apple Notes from here — paste keys from your Notes into this file locally.

# ------------------------------
# Preferred routing (subscriptions / first-party APIs)
# ------------------------------
# AgentRouter — first hop in gateway fallbacks + first entry in LiteLLM fallbacks (when key set).
# One key line only: duplicate env keys make the LAST one win in python-dotenv.
AGENTROUTER_API_KEY=
# AGENT_ROUTER_TOKEN=   # alias from AgentRouter Codex docs — same as API key
AGENTROUTER_API_BASE=https://agentrouter.org/v1
#
# Optional global override (applies to kitty-default when set):
# AGENTROUTER_MODEL=gpt-5.4-mini
# KITTY_AGENTROUTER_CHAT_MODEL=gpt-5.4-mini
#
# Per-tier upstream model (short OpenAI-style ids — confirm in AgentRouter console /v1/models):
# Defaults in code if unset:
#   kitty-default → gpt-5.4-mini   (cheap chat + tools)
#   kitty-smart   → gpt-5.5        (strong companion / “use your best” tier)
#   kitty-agent   → gpt-5.1-codex-mini + kitty-parts (cheap coding — mini codex)
#
# KITTY_AGENTROUTER_MODEL_DEFAULT=
# KITTY_AGENTROUTER_MODEL_AGENT=
# KITTY_AGENTROUTER_MODEL_SMART=
# KITTY_AGENTROUTER_MODEL_PARTS=
# Flagship coding (more $, better tool use) when you outgrow the mini:
# KITTY_AGENTROUTER_CODING_MODEL=gpt-5.3-codex
#
# Fingerprint / “unauthorized client”: set extra headers from their support/Discord (JSON object):
# KITTY_AGENTROUTER_EXTRA_HEADERS_JSON={"X-Custom":"value"}
# KITTY_AGENTROUTER_USER_AGENT=   # overrides default OpenAI-style UA
# KITTY_AGENTROUTER_NO_ALT_UA_RETRY=1   # disable browser-UA retry after 401

# Librarian / knowledge ingestion (gateway/librarian.py) — LiteLLM virtual name; uses cheap stack
# defined for kitty-default in kitty_gateway/litellm_config.yaml (DeepSeek Flash → Qwen free → Gemini…).
KITTY_INGEST_LLM_MODEL=kitty-fallback-or

# When the LiteLLM proxy fails, gateway/llm_client.py calls OpenRouter directly using these IDs:
KITTY_OPENROUTER_CHEAP=deepseek/deepseek-v4-flash
KITTY_OPENROUTER_REASONING=deepseek/deepseek-v4-flash
KITTY_OPENROUTER_BEST=claude-sonnet-4-6
# Override all direct-OpenRouter fallbacks with one id (optional):
#KITTY_OPENROUTER_DIRECT_MODEL=qwen/qwen3-235b-a22b:free

# Anthropic (Claude API — billed; not the same as Claude Pro in the app unless you use API)
ANTHROPIC_API_KEY=

# Google Gemini API (AI Studio key)
# LiteLLM `gemini/...` models in litellm_config.yaml read GEMINI_API_KEY.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# OpenAI platform API (ChatGPT/Codex-style API access uses this key)
OPENAI_API_KEY=

# NVIDIA NIM / integrate API (OpenAI-compatible chat)
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=deepseek-ai/deepseek-v4-pro

# ------------------------------
# Optional: OpenRouter (fallback when others fail or for free-tier models)
# ------------------------------
OPENROUTER_API_KEY=
KITTY_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
USE_OPENROUTER=true

# ------------------------------
# LiteLLM proxy (local) — must match kitty_gateway/litellm_config.yaml
# ------------------------------
LITELLM_BASE=http://localhost:8001
LITELLM_KEY=kitty-local-key-change-me
LITELLM_MASTER_KEY=kitty-local-key-change-me
LITELLM_MAX_BUDGET_USD=2.00

# Legacy alias (some scripts mention this name — prefer LITELLM_KEY)
LITELLM_API_KEY=kitty-local-key-change-me

# Routing toggles (gateway/llm_client.py — see route_model / LiteLLM failure chain)
# KITTY_DISABLE_LOCAL=1           # offline probe says “down”: skip mlx-local shortcut, use keyword routing
# KITTY_DISABLE_AGENTROUTER=1      # LiteLLM failure: skip AgentRouter direct, try OpenRouter/etc.

# ------------------------------
# Gateway / OpenWebUI
# ------------------------------
GATEWAY_SECRET=
KITTY_WEBUI_ORIGIN=
