# Copy to `.env` in this directory (same folder as `web.py`). Never commit `.env`.
# Shell exports override values loaded from `.env` (override=False in web.py).

# Required for cloud fallback when local MLX is off or exhausted:
OPENROUTER_API_KEY=

# Optional OpenRouter model IDs (see https://openrouter.ai/models )
KITTY_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
USE_OPENROUTER=true

# Default SSE/socket tier when the UI omits `mode`: fast | balanced | max
# `balanced` prefers OpenRouter when MLX is not forced (legacy default was `fast`).
# KITTY_WEB_DEFAULT_MODE=balanced

# ------------------------------
# Gateway / OpenWebUI bridge
# ------------------------------
# Bearer secret required by gateway auth middleware
GATEWAY_SECRET=

# Optional custom webui origin (e.g., tailscale URL); defaults include localhost
KITTY_WEBUI_ORIGIN=

# Local LiteLLM API key used by gateway -> LiteLLM requests
LITELLM_API_KEY=kitty-local-key-change-me
