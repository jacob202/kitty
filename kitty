#!/usr/bin/env bash
# Kitty launcher — one command to run, stop, and inspect the stack.
#
# Usage:
#   kitty           Start gateway + LiteLLM + UI and open the browser (default)
#   kitty up        Start gateway + LiteLLM (background, logs to logs/)
#   kitty down      Stop both
#   kitty status    Show what's running + health check
#   kitty doctor    Full preflight check (gateway/doctor.py)
#   kitty context --agent  Print deterministic repository continuity JSON
#   kitty logs      Tail live logs for both services
#   kitty backup    Back up app-owned data under data/backups/kitty/
#   kitty restore-drill BACKUP_DIR RESTORE_DIR
#   kitty install   Install launchd plists so the stack auto-starts on reboot
#   kitty uninstall Remove launchd plists
#   kitty run-fg    Run gateway in foreground (for debugging)
#   kitty resume    Print one-screen orientation block (branch, PRs, tests, services, packets)
#   kitty builder <cmd>        Run Kitty Builder Layer 1A (brief, contract validate)
#   kitty delegate <action-id>  Generate a docs/packets/NNN-slug.md file from an action
#   kitty tutor learn <path>     Ingest a doc into the Tutor (RAG learning)
#   kitty tutor ask "<q>"        Vocab-first answer + one check-in question
#   kitty tutor review           Show terms you struggled with, due now
#   kitty tutor rate "<term>" <1-3>  Log confidence (1 got it, 2 need example, 3 lost)
#   kitty push [--alert] "message"  Push to Jacob's phone (iMessage, Pushover fallback)
#   kitty project add "name" /abs/path [kind]   Register a project (kind: code|admin|creative|...)
#   kitty project list                          List registered projects
#   kitty project refresh <id>                  Recompose state + regenerate the next step ("B")
#   kitty project next <id>                     Show the current next step for a project
#   kitty project set-path <id> /abs/path       Fix a project's path
#   kitty verify-home   Start gateway+UI if needed, check health + tailnet, print the iPhone URL
#
# Environment: reads .env from the repo root if present. All overrides
# (GATEWAY_PORT, LITELLM_PORT, LITELLM_VENV, …) live in .env, never here.

set -euo pipefail

KITTY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export KITTY_ROOT

RUN_DIR="$KITTY_ROOT/logs/.run"
LOG_DIR="$KITTY_ROOT/logs"

# ── Load .env ────────────────────────────────────────────────────────────────
export PYTHON_BIN="${PYTHON_BIN:-$KITTY_ROOT/venv/bin/python}"
source "$KITTY_ROOT/gateway/lib/load_env_safe.sh"

if [[ -f "$KITTY_ROOT/.env" ]]; then
  load_env_assignments "$KITTY_ROOT/.env"
fi

GATEWAY_PORT="${GATEWAY_PORT:-8000}"
LITELLM_PORT="${LITELLM_PORT:-8001}"
LITELLM_MASTER_KEY="${LITELLM_MASTER_KEY:-kitty-local-key-change-me}"
UI_PORT="${UI_PORT:-4000}"

# ── Helpers ───────────────────────────────────────────────────────────────────
mkdir -p "$RUN_DIR" "$LOG_DIR"

pid_alive() {
  local pidfile="$1"
  [[ -f "$pidfile" ]] && kill -0 "$(cat "$pidfile")" 2>/dev/null
}

launchd_pid() {
  local svc="$1"
  launchctl print "gui/$(id -u)/com.kitty.$svc" 2>/dev/null \
    | awk -F'= ' '/^[[:space:]]*pid = / { print $2; exit }'
}

http_ok() {
  local url="$1"; shift
  curl -sf --max-time 3 "$@" "$url" >/dev/null 2>&1
}

generate_secret() {
  local python="$KITTY_ROOT/venv/bin/python"
  if [[ ! -x "$python" ]]; then
    python="$(command -v python3)"
  fi
  "$python" - <<'PY'
import secrets
print(secrets.token_urlsafe(32))
PY
}

append_env_secret() {
  local key="$1"
  local value="$2"
  local env_file="$KITTY_ROOT/.env"

  if [[ ! -f "$env_file" ]]; then
    umask 077
    : > "$env_file"
  fi

  {
    echo
    echo "# Generated by ./kitty for local gateway auth"
    echo "$key=$value"
  } >> "$env_file"
  chmod 600 "$env_file" 2>/dev/null || true
}

ensure_gateway_secret() {
  local secret="${GATEWAY_SECRET:-${KITTY_GATEWAY_SECRET:-}}"
  local generated=0

  if [[ -z "$secret" ]]; then
    secret="$(generate_secret)"
    generated=1
  fi

  if [[ -z "${GATEWAY_SECRET:-}" ]]; then
    append_env_secret "GATEWAY_SECRET" "$secret"
    export GATEWAY_SECRET="$secret"
  fi

  if [[ -z "${KITTY_GATEWAY_SECRET:-}" ]]; then
    append_env_secret "KITTY_GATEWAY_SECRET" "$secret"
    export KITTY_GATEWAY_SECRET="$secret"
  fi

  if [[ "$generated" == "1" ]]; then
    echo "  Generated local gateway secret in .env"
  fi
}

# ── Subcommands ───────────────────────────────────────────────────────────────
cmd_up() {
  echo "Starting Kitty..."
  ensure_gateway_secret

  # LiteLLM
  if pid_alive "$RUN_DIR/litellm.pid"; then
    echo "  LiteLLM  already running (pid $(cat "$RUN_DIR/litellm.pid"))"
  else
    nohup bash "$KITTY_ROOT/gateway/start_litellm.sh" \
      >"$LOG_DIR/litellm.log" 2>&1 &
    echo $! >"$RUN_DIR/litellm.pid"
    echo "  LiteLLM  started (pid $!)"
  fi

  # Gateway
  if pid_alive "$RUN_DIR/gateway.pid"; then
    echo "  Gateway  already running (pid $(cat "$RUN_DIR/gateway.pid"))"
  else
    nohup bash "$KITTY_ROOT/gateway/start_gateway.sh" \
      >"$LOG_DIR/gateway.log" 2>&1 &
    echo $! >"$RUN_DIR/gateway.pid"
    echo "  Gateway  started (pid $!)"
  fi

  # Poll up to 15 seconds for gateway to be healthy
  echo "  Waiting for gateway..."
  _i=0
  while [ $_i -lt 15 ]; do
    if http_ok "http://127.0.0.1:$GATEWAY_PORT/health"; then
      echo "  Gateway  healthy ✓  http://127.0.0.1:$GATEWAY_PORT"
      break
    fi
    sleep 1
    _i=$((_i + 1))
  done
  if [ $_i -ge 15 ]; then
    echo "  Gateway  not responding yet — check: kitty logs"
  fi
}

cmd_start() {
  # One-shot launch: gateway + LiteLLM + UI, then open the browser.
  cmd_up

  if ! http_ok "http://127.0.0.1:$UI_PORT/"; then
    echo "Starting UI on http://localhost:$UI_PORT ..."
    (cd "$KITTY_ROOT/gateway/kitty-chat" \
      && nohup node node_modules/next/dist/bin/next dev -H 127.0.0.1 -p "$UI_PORT" \
        >"$LOG_DIR/ui.log" 2>&1 &)
    _i=0
    while [ $_i -lt 30 ]; do
      if http_ok "http://127.0.0.1:$UI_PORT/"; then break; fi
      sleep 1
      _i=$((_i + 1))
    done
  fi

  if http_ok "http://127.0.0.1:$UI_PORT/"; then
    echo "UI ready: http://localhost:$UI_PORT"
    if command -v open >/dev/null 2>&1; then
      open "http://localhost:$UI_PORT"
    fi
  else
    echo "UI not responding on :$UI_PORT — check: $LOG_DIR/ui.log"
  fi
}

cmd_down() {
  echo "Stopping Kitty..."
  for svc in gateway litellm; do
    pidfile="$RUN_DIR/$svc.pid"
    if pid_alive "$pidfile"; then
      pid=$(cat "$pidfile")
      # Kill the process group so child processes (uvicorn workers) also die
      pkill -P "$pid" 2>/dev/null || true
      kill "$pid" 2>/dev/null || true
      rm -f "$pidfile"
      echo "  $svc  stopped (was pid $pid)"
    else
      echo "  $svc  not running"
    fi
  done
}

cmd_status() {
  echo "Kitty status"
  echo "────────────"

  for svc in gateway litellm; do
    pidfile="$RUN_DIR/$svc.pid"
    if pid_alive "$pidfile"; then
      pid=$(cat "$pidfile")
      printf "  %-10s running (pid %s)\n" "$svc" "$pid"
    elif launch_pid="$(launchd_pid "$svc")" && [[ -n "$launch_pid" ]]; then
      printf "  %-10s running via launchd (pid %s)\n" "$svc" "$launch_pid"
    else
      printf "  %-10s not running\n" "$svc"
    fi
  done

  echo
  echo "Health checks"
  echo "─────────────"

  if http_ok "http://127.0.0.1:$GATEWAY_PORT/health"; then
    echo "  gateway   http://127.0.0.1:$GATEWAY_PORT  ✓"
  else
    echo "  gateway   http://127.0.0.1:$GATEWAY_PORT  ✗  (not responding)"
  fi

  if http_ok "http://127.0.0.1:$LITELLM_PORT/health/readiness" \
       -H "Authorization: Bearer $LITELLM_MASTER_KEY"; then
    echo "  litellm   http://127.0.0.1:$LITELLM_PORT  ✓"
  else
    echo "  litellm   http://127.0.0.1:$LITELLM_PORT  ✗  (not responding)"
  fi

  echo
  echo "Frontend: http://localhost:4000 (run separately: cd gateway/kitty-chat && npm run dev)"
}

cmd_doctor() {
  VENV="$KITTY_ROOT/venv"
  if [[ -x "$VENV/bin/python" ]]; then
    "$VENV/bin/python" "$KITTY_ROOT/gateway/doctor.py" "$@"
  else
    python3 "$KITTY_ROOT/gateway/doctor.py" "$@"
  fi
}

cmd_context() {
  local python_bin="$KITTY_ROOT/venv/bin/python"
  if [[ ! -x "$python_bin" ]]; then
    python_bin="$(command -v python3.12)"
  fi
  PYTHONPATH="$KITTY_ROOT${PYTHONPATH:+:$PYTHONPATH}" \
    "$python_bin" -m gateway.context_receipt "$@"
}

cmd_logs() {
  echo "Tailing logs/gateway.log and logs/litellm.log (Ctrl-C to stop)..."
  tail -f "$LOG_DIR/gateway.log" "$LOG_DIR/litellm.log" 2>/dev/null || \
    echo "No log files yet — run: kitty up"
}

cmd_backup() {
  "$PYTHON_BIN" "$KITTY_ROOT/scripts/kitty_backup.py" backup "$@"
}

cmd_restore_drill() {
  "$PYTHON_BIN" "$KITTY_ROOT/scripts/kitty_backup.py" restore-drill "$@"
}

cmd_install() {
  ensure_gateway_secret
  LAUNCH_AGENTS="$HOME/Library/LaunchAgents"
  mkdir -p "$LAUNCH_AGENTS"

  for svc in gateway litellm; do
    src="$KITTY_ROOT/gateway/com.kitty.$svc.plist"
    dst="$LAUNCH_AGENTS/com.kitty.$svc.plist"

    # Stamp the actual KITTY_ROOT into the plist before installing
    sed "s|__KITTY_ROOT__|$KITTY_ROOT|g" "$src" >"$dst"

    # Unload first so a re-install is idempotent
    launchctl unload "$dst" 2>/dev/null || true
    launchctl load -w "$dst"
    echo "  Installed com.kitty.$svc"
  done

  echo
  echo "Stack will now start automatically on login and restart on crash."
  echo "Run 'kitty status' to verify."
}

cmd_uninstall() {
  LAUNCH_AGENTS="$HOME/Library/LaunchAgents"
  for svc in gateway litellm; do
    dst="$LAUNCH_AGENTS/com.kitty.$svc.plist"
    if [[ -f "$dst" ]]; then
      launchctl unload "$dst" 2>/dev/null || true
      rm "$dst"
      echo "  Removed com.kitty.$svc"
    fi
  done
}

cmd_run_fg() {
  ensure_gateway_secret
  echo "Running gateway in foreground (Ctrl-C to stop)..."
  GATEWAY_RELOAD="${GATEWAY_RELOAD:-1}" bash "$KITTY_ROOT/gateway/start_gateway.sh"
}

cmd_resume() {
  VENV="$KITTY_ROOT/venv"
  if [[ -x "$VENV/bin/python" ]]; then
    "$VENV/bin/python" "$KITTY_ROOT/scripts/resume.py"
  else
    python3.12 "$KITTY_ROOT/scripts/resume.py"
  fi
}

cmd_builder() {
  local python_bin="$KITTY_ROOT/venv/bin/python"
  if [[ ! -x "$python_bin" ]]; then
    python_bin="$(command -v python3.12)"
  fi
  "$python_bin" -m gateway.builder_cli "$@"
}

cmd_tutor() {
  local python_bin="$KITTY_ROOT/venv/bin/python"
  if [[ ! -x "$python_bin" ]]; then
    python_bin="$(command -v python3.12)"
  fi
  "$python_bin" -m gateway.tutor_cli "$@"
}

cmd_delegate() {
  local action_id="${1:-}"
  if [[ -z "$action_id" ]]; then
    echo "Usage: kitty delegate <action-id>" >&2
    exit 1
  fi
  "$PYTHON_BIN" -m gateway.delegation "$action_id"
}

cmd_push() {
  local alert=0
  local message=""
  for arg in "$@"; do
    case "$arg" in
      --alert) alert=1 ;;
      *) message="$arg" ;;
    esac
  done
  if [[ -z "$message" ]]; then
    echo "Usage: kitty push [--alert] \"message\"" >&2
    exit 1
  fi
  local kind="info"
  [[ "$alert" -eq 1 ]] && kind="alert"
  PYTHONPATH="$KITTY_ROOT${PYTHONPATH:+:$PYTHONPATH}" "$PYTHON_BIN" -c '
import sys
from gateway.push import push_to_jacob
ok = push_to_jacob(sys.argv[1], kind=sys.argv[2], title="Kitty")
print("sent" if ok else "failed — see logs/push_log.jsonl")
sys.exit(0 if ok else 1)
' "$message" "$kind"
}

cmd_sweep() {
  PYTHONPATH="$KITTY_ROOT${PYTHONPATH:+:$PYTHONPATH}" "$PYTHON_BIN" -c '
import json
from gateway.deadline_sweep import sweep
report = sweep(push_fn=None)
print(json.dumps(report, indent=2, default=str))
'
}

cmd_project() {
  local sub="${1:-}"
  shift || true
  local base="http://127.0.0.1:$GATEWAY_PORT"

  if [[ -z "${GATEWAY_SECRET:-}" ]]; then
    echo "GATEWAY_SECRET not set — run: kitty up (it writes one into .env)" >&2
    exit 1
  fi

  # All output shaping happens in one python helper so quoting in project
  # names can never break the shell or the JSON.
  project_py() {
    PYTHONPATH="$KITTY_ROOT${PYTHONPATH:+:$PYTHONPATH}" "$PYTHON_BIN" - "$@" <<'PY'
import json
import os
import sys
import urllib.error
import urllib.request

try:
    # Both expected to be set by cmd_project() before this heredoc runs;
    # treat absent as a hard fail so we don't chase a phantom error through
    # the rest of the function. See audit §2.4 / AUDIT_FULL_ENGINEERING_2026-07-20.md.
    base = os.environ["KITTY_PROJECT_BASE"]
    secret = os.environ["GATEWAY_SECRET"]
except KeyError as exc:
    missing = exc.args[0]
    print(
        f"missing env var: {missing} — run: kitty up "
        f"(it writes GATEWAY_SECRET into .env)",
        file=sys.stderr,
    )
    sys.exit(2)
mode = sys.argv[1]
args = sys.argv[2:]


def call(method, path, payload=None):
    data = json.dumps(payload).encode() if payload is not None else None
    req = urllib.request.Request(
        base + path,
        data=data,
        method=method,
        headers={"Authorization": f"Bearer {secret}", "Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            return json.load(resp)
    except urllib.error.HTTPError as exc:
        body = exc.read().decode(errors="replace")
        print(f"gateway said {exc.code}: {body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as exc:
        print(f"can't reach the gateway at {base} — is it up? ({exc.reason})", file=sys.stderr)
        sys.exit(1)


def show_step(step):
    if not step:
        return
    if step.get("ok") is False:
        print(f"  B: unavailable — {step.get('error')}")
        return
    print(f"  B: {step.get('step')}")
    if step.get("why"):
        print(f"     why: {step['why']}")
    if step.get("recent_win"):
        print(f"     already done: {step['recent_win']}")
    if step.get("delegable"):
        print("     (delegable to an agent)")


if mode == "add":
    name, path, kind = args
    p = call("POST", "/projects", {"name": name, "kind": kind, "paths": [path]})
    print(f"registered #{p['id']}: {p['name']} ({p['kind']}) -> {', '.join(p['paths'])}")
    print(f"next: kitty project refresh {p['id']}")
elif mode == "list":
    projects = call("GET", "/projects")["projects"]
    if not projects:
        print("no projects registered yet — kitty project add \"name\" /abs/path")
    for p in projects:
        paths = ", ".join(p["paths"]) or "(no path)"
        print(f"#{p['id']:<3} {p['name']:<28} {p['kind']:<9} {p['status']:<9} {paths}")
elif mode == "refresh":
    (project_id,) = args
    p = call("POST", f"/projects/{project_id}/refresh")
    print(f"#{p['id']} {p['name']}: {p.get('summary') or 'no data yet'}")
    for name, src in (p.get("sources") or {}).items():
        if not src.get("ok"):
            print(f"  source {name}: FAILED — {src.get('error')}")
    show_step(p.get("next_step"))
elif mode == "next":
    (project_id,) = args
    step = call("GET", f"/projects/{project_id}/next")
    show_step({"ok": True, **step})
elif mode == "set-path":
    project_id, path = args
    p = call("PATCH", f"/projects/{project_id}", {"paths": [path]})
    print(f"#{p['id']} {p['name']} -> {', '.join(p['paths'])}")
PY
  }

  export KITTY_PROJECT_BASE="$base"
  case "$sub" in
    add)
      local name="${1:-}" path="${2:-}" kind="${3:-code}"
      if [[ -z "$name" || -z "$path" ]]; then
        echo 'Usage: kitty project add "name" /abs/path [kind]' >&2
        exit 1
      fi
      project_py add "$name" "$path" "$kind"
      ;;
    list)
      project_py list
      ;;
    refresh)
      if [[ -z "${1:-}" ]]; then echo "Usage: kitty project refresh <id>" >&2; exit 1; fi
      project_py refresh "$1"
      ;;
    next)
      if [[ -z "${1:-}" ]]; then echo "Usage: kitty project next <id>" >&2; exit 1; fi
      project_py next "$1"
      ;;
    set-path)
      if [[ -z "${1:-}" || -z "${2:-}" ]]; then echo "Usage: kitty project set-path <id> /abs/path" >&2; exit 1; fi
      project_py set-path "$1" "$2"
      ;;
    *)
      echo "Usage: kitty project add|list|refresh|next|set-path" >&2
      exit 1
      ;;
  esac
}

cmd_verify_home() {
  # Is the Home cockpit actually reachable, end to end? Exits 0 only when
  # gateway, UI, and tailnet all check out. LiteLLM is report-only: chat
  # routing breaks without it, but Home still loads and says so honestly.
  local fails=0
  local ui_port="${UI_PORT:-4000}"

  if ! http_ok "http://127.0.0.1:$GATEWAY_PORT/health"; then
    echo "gateway   not running — starting via ./kitty up"
    cmd_up
  fi
  if http_ok "http://127.0.0.1:$GATEWAY_PORT/health"; then
    echo "gateway   ✓  http://127.0.0.1:$GATEWAY_PORT"
    if curl -sf --max-time 3 "http://127.0.0.1:$GATEWAY_PORT/health" 2>/dev/null \
        | grep -q '"litellm_reachable": *true'; then
      echo "litellm   ✓  reachable (via gateway /health)"
    else
      echo "litellm   ✗  gateway reports it unreachable — chat routing is down, home still works"
    fi
  else
    echo "gateway   ✗  not responding — check: kitty logs"
    fails=1
  fi

  if ! http_ok "http://127.0.0.1:$ui_port/"; then
    echo "ui        not running — starting bound to all interfaces (logs: $LOG_DIR/ui.log)"
    (cd "$KITTY_ROOT/gateway/kitty-chat" \
      && nohup node node_modules/next/dist/bin/next dev -H 127.0.0.1 -p "$ui_port" \
        >"$LOG_DIR/ui.log" 2>&1 &)
    _i=0
    while [ $_i -lt 30 ]; do
      if http_ok "http://127.0.0.1:$ui_port/"; then break; fi
      sleep 1
      _i=$((_i + 1))
    done
  fi
  if http_ok "http://127.0.0.1:$ui_port/"; then
    echo "ui        ✓  http://localhost:$ui_port"
  else
    echo "ui        ✗  not responding on :$ui_port — check: $LOG_DIR/ui.log"
    fails=1
  fi

  local ts_ip=""
  if command -v tailscale >/dev/null 2>&1; then
    ts_ip="$(tailscale ip -4 2>/dev/null | head -1 || true)"
  fi
  if [[ -z "$ts_ip" ]]; then
    # Tailscale hands out addresses in the CGNAT 100.64/10 range.
    ts_ip="$(ifconfig 2>/dev/null | awk '/inet 100\./ { print $2; exit }' || true)"
  fi
  if [[ -z "$ts_ip" ]]; then
    echo "tailnet   ✗  no tailscale interface — install/start Tailscale on this machine"
    fails=1
  elif http_ok "http://$ts_ip:$ui_port/"; then
    echo "tailnet   ✓  your iPhone can reach Kitty at: http://$ts_ip:$ui_port"
  else
    echo "tailnet   ✗  tailscale is up ($ts_ip) but the UI isn't reachable on it —"
    echo "             the UI is bound to loopback. restart it with: make ui-tailnet"
    fails=1
  fi

  if [ "$fails" -eq 0 ]; then
    echo "verify-home: all checks passed ✓"
  else
    echo "verify-home: FAILED — fix the ✗ lines above"
  fi
  return "$fails"
}

cmd_help() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# //' | head -23
}

# ── Dispatch ─────────────────────────────────────────────────────────────────
case "${1:-start}" in
  start)     cmd_start ;;
  up)        cmd_up ;;
  down)      cmd_down ;;
  status)    cmd_status ;;
  doctor)    shift; cmd_doctor "$@" ;;
  context)   shift; cmd_context "$@" ;;
  logs)      cmd_logs ;;
  backup)    shift; cmd_backup "$@" ;;
  restore-drill) shift; cmd_restore_drill "$@" ;;
  install)   cmd_install ;;
  uninstall) cmd_uninstall ;;
  run-fg)    cmd_run_fg ;;
  resume)    cmd_resume ;;
  builder)   shift; cmd_builder "$@" ;;
  delegate)  shift; cmd_delegate "$1" ;;
  push)      shift; cmd_push "$@" ;;
  sweep)     cmd_sweep ;;
  project)   shift; cmd_project "$@" ;;
  tutor)     shift; cmd_tutor "$@" ;;
  verify-home) cmd_verify_home ;;
  help|--help|-h) cmd_help ;;
  *)
    echo "Unknown command: ${1}" >&2
    echo "Run 'kitty help' for usage." >&2
    exit 1
    ;;
esac
