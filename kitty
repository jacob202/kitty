#!/bin/zsh
# Kitty launcher — run from anywhere: ./kitty or add to PATH
# Usage:
#   ./kitty          start web server (default port 5001)
#   ./kitty stop     kill running server
#   ./kitty restart  stop + start
#   ./kitty status   show if running + URL
#   ./kitty logs     tail the log file
#   ./kitty ref      show terminal quick reference
#   ./kitty backup   create backup of all data stores
#   ./kitty export   export session as markdown

PYTHON=venv/bin/python
SCRIPT_DIR="${0:A:h}"
PIDFILE="$SCRIPT_DIR/.kitty.pid"
LOGFILE="$SCRIPT_DIR/.kitty.log"
PORT="${KITTY_PORT:-5001}"
CURL="${CURL:-/usr/bin/curl}"
[[ -x "$CURL" ]] || CURL="curl"

_ip() {
  python3 -c "import socket; s=socket.socket(); s.settimeout(1); s.connect(('8.8.8.8',80)); print(s.getsockname()[0]); s.close()" 2>/dev/null || echo "127.0.0.1"
}

_port_pid() {
  lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null | head -1
}

_pidfile_pid() {
  [[ -f "$PIDFILE" ]] && cat "$PIDFILE" 2>/dev/null
}

_pid_alive() {
  [[ -n "$1" ]] && kill -0 "$1" 2>/dev/null
}

_start() {
  local port_pid=$(_port_pid)
  if [[ -n "$port_pid" ]]; then
    echo "$port_pid" > "$PIDFILE"
    echo "Kitty is already running (PID $port_pid) — http://localhost:$PORT"
    return 0
  fi

  local file_pid=$(_pidfile_pid)
  if _pid_alive "$file_pid"; then
    echo "Ignoring stale Kitty PID $file_pid; it is not listening on port $PORT"
  fi
  rm -f "$PIDFILE"

  echo "Starting Kitty…"
  local pid
  pid=$(SCRIPT_DIR="$SCRIPT_DIR" LOGFILE="$LOGFILE" PYTHON="$PYTHON" "$PYTHON" - <<'PY'
import os
import subprocess

script_dir = os.environ["SCRIPT_DIR"]
logfile = os.environ["LOGFILE"]
python = os.environ["PYTHON"]

log = open(logfile, "ab", buffering=0)
process = subprocess.Popen(
    [python, "web.py"],
    cwd=script_dir,
    stdin=subprocess.DEVNULL,
    stdout=log,
    stderr=subprocess.STDOUT,
    close_fds=True,
    start_new_session=True,
)
print(process.pid)
PY
  )
  echo "$pid" > "$PIDFILE"

  # Wait for server to be ready (max 30s)
  local waited=0
  until "$CURL" -sf "http://localhost:$PORT/" > /dev/null 2>&1; do
    sleep 0.5
    (( waited++ ))
    [[ $waited -ge 60 ]] && { echo "Server didn't respond after 30s — check .kitty.log"; return 1; }
  done

  local ip=$(_ip)
  echo ""
  echo "  ┌────────────────────────────────────────┐"
  echo "  │  🐱  Kitty is live                     │"
  echo "  │                                        │"
  printf "  │  Local  →  http://localhost:%s        │\n" "$PORT"
  printf "  │  Phone  →  http://%s:%s  │\n" "$ip" "$PORT"
  echo "  └────────────────────────────────────────┘"
  echo ""

  # Open browser on macOS
  if [[ "$OSTYPE" == darwin* ]]; then
    open "http://localhost:$PORT" 2>/dev/null
  fi
}

_stop() {
  local file_pid=$(_pidfile_pid)
  local port_pid=$(_port_pid)
  local stopped=0

  if [[ -n "$port_pid" ]]; then
    kill "$port_pid" && echo "Kitty stopped (PID $port_pid)"
    stopped=1
  fi

  if _pid_alive "$file_pid" && [[ "$file_pid" != "$port_pid" ]]; then
    kill "$file_pid" && echo "Stopped stale Kitty PID $file_pid"
    stopped=1
  fi

  rm -f "$PIDFILE"

  if [[ "$stopped" -eq 0 ]]; then
    echo "Kitty doesn't appear to be running"
  fi
}

_status() {
  local file_pid=$(_pidfile_pid)
  local running_pid=$(_port_pid)

  if [[ -n "$running_pid" ]]; then
    if [[ "$running_pid" != "$file_pid" ]]; then
      echo "$running_pid" > "$PIDFILE"
    fi
    local ip=$(_ip)
    echo "  running  PID $running_pid"
    echo "  local    http://localhost:$PORT"
    echo "  phone    http://$ip:$PORT"
  else
    if _pid_alive "$file_pid" ]; then
      echo "  stopped  stale PID $file_pid is alive but not listening on port $PORT"
    fi
    rm -f "$PIDFILE"
    echo "  stopped"
  fi
}

_backup() {
  local backup_dir="$SCRIPT_DIR/data/backups"
  mkdir -p "$backup_dir"
  local timestamp=$(date +"%Y%m%d_%H%M%S")
  local backup_file="$backup_dir/kitty_backup_$timestamp.tar.gz"

  echo "Creating backup…"

  # Backup all data stores
  local data_dir="$SCRIPT_DIR/data"
  if [[ -d "$data_dir" ]]; then
    tar -czf "$backup_file" -C "$SCRIPT_DIR" data 2>/dev/null
    echo "✓ Backup created: $backup_file"
  else
    echo "No data directory found"
    return 1
  fi
}

_export() {
  local export_dir="$SCRIPT_DIR/data/exports"
  mkdir -p "$export_dir"
  local timestamp=$(date +"%Y%m%d_%H%M%S")
  local export_file="$export_dir/session_$timestamp.md"

  echo "Exporting session…"

  # Call the API to export
  if "$CURL" -sf "http://localhost:$PORT/api/brief" > "$export_file" 2>/dev/null; then
    echo "✓ Exported: $export_file"
  else
    echo "✗ Export failed (server not running?)"
    rm -f "$export_file"
    return 1
  fi
}

_problems() {
  local found=0

  echo "🐱 Kitty Health Check"
  echo ""

  # Server status
  local running=$(_port_pid)
  if [[ -n "$running" ]]; then
    echo "  ✓  Server is running (PID $running)"
  else
    echo "  ✗  Server is stopped"
    ((found++))
  fi

  # API key
  if [[ -n "$OPENROUTER_API_KEY" ]] || grep -q "OPENROUTER_API_KEY=" "$SCRIPT_DIR/.env" 2>/dev/null; then
    echo "  ✓  OpenRouter API key is set"
  else
    echo "  ✗  OpenRouter API key is not set — LLM calls will fail"
    ((found++))
  fi

  # Stale backup files
  local stale=$(find "$SCRIPT_DIR" -maxdepth 2 \( -name "*.bak" -o -name "*.fixed" -o -name "*.backup2" \) 2>/dev/null)
  if [[ -z "$stale" ]]; then
    echo "  ✓  No stale backup files found"
  else
    echo "  ✗  Stale backup files found:"
    echo "$stale" | while read f; do echo "      $f"; done
    ((found++))
  fi

  # Test pass count (quick: run last line of pytest summary)
  local test_out
  test_out=$(cd "$SCRIPT_DIR" && "$PYTHON" -m pytest tests/ -q --tb=short 2>/dev/null | tail -1)
  if [[ "$test_out" == *passed* ]]; then
    echo "  ✓  Tests: $test_out"
  elif [[ -n "$test_out" ]]; then
    echo "  ✗  Tests: $test_out"
    ((found++))
  else
    echo "  ?  Could not run tests"
  fi

  echo ""
  if (( found > 0 )); then
    echo "  $found problem(s) found. Say \"fix the problems\" to an agent."
  else
    echo "  All clear ✓"
  fi
}

_briefing() {
  echo "🐱 Kitty Briefing"
  echo ""

  # Current focus
  if [[ -f "$SCRIPT_DIR/CURRENT_FOCUS.md" ]]; then
    head -10 "$SCRIPT_DIR/CURRENT_FOCUS.md" | grep -v "^# " | grep -v "^Last updated" | grep -v "^$" | head -5
    echo ""
  fi

  # Recent commits
  echo "  Recent changes:"
  cd "$SCRIPT_DIR" && git log --oneline --format="  • %s" -5 2>/dev/null
  echo ""

  # Test count
  local test_out
  test_out=$(cd "$SCRIPT_DIR" && "$PYTHON" -m pytest tests/ -q --tb=short 2>/dev/null | tail -1)
  if [[ -n "$test_out" ]]; then
    echo "  Tests: $test_out"
  fi

  # Server status
  local running=$(_port_pid)
  if [[ -n "$running" ]]; then
    echo "  Kitty server: running (http://localhost:$PORT)"
  else
    echo "  Kitty server: stopped (run ./kitty start)"
  fi
}

_quick() {
  local cmd="${2:-}"
  case "$cmd" in
    status)
      _status
      ;;
    count|lines)
      local target="${3:-.}"
      if [[ -d "$target" ]]; then
        find "$target" -name "*.py" -type f | xargs wc -l 2>/dev/null | tail -1
      elif [[ -f "$target" ]]; then
        wc -l "$target"
      else
        echo "Usage: ./kitty quick count <file-or-dir>"
      fi
      ;;
    test)
      cd "$SCRIPT_DIR"
      "$PYTHON" -m pytest tests/ -q --tb=short -x "${3:-}" 2>/dev/null || echo "pytest not available"
      ;;
    health)
      "$CURL" -sf "http://localhost:$PORT/api/brief" >/dev/null 2>&1 && echo "✓ API responding" || echo "✗ API not responding"
      ;;
    tokens)
      tail -5 "$SCRIPT_DIR/data/kitty_token_log.jsonl" 2>/dev/null | while read line; do
        echo "$line" | python3 -c "import json,sys; d=json.load(sys.stdin); print(f&quot;{d.get('date','')} {d.get('model','')} {d.get('usage',{}).get('total_tokens',0)}&quot;)" 2>/dev/null
      done
      ;;
    index)
      cd "$SCRIPT_DIR"
      shift 2
      "$PYTHON" scripts/build_file_index.py --search "${3:-}" 2>/dev/null || echo "Usage: ./kitty quick index <pattern>"
      ;;
    *)
      echo "Quick deterministic commands (no LLM):"
      echo "  ./kitty quick status      — server status"
      echo "  ./kitty quick count <path>  — count lines in file/dir"
      echo "  ./kitty quick test       — run pytest"
      echo "  ./kitty quick health  — check API"
      echo "  ./kitty quick tokens  — show recent tokens"
      echo "  ./kitty quick index <pattern>  — search file index"
      ;;
  esac
}

case "${1:-start}" in
  start)    _start ;;
  stop)     _stop ;;
  restart)  _stop; sleep 1; _start ;;
  status)   _status ;;
  problems) _problems ;;
  briefing) _briefing ;;
  logs)    tail -f "$LOGFILE" ;;
  ref)     cd "$SCRIPT_DIR" && "$PYTHON" "$SCRIPT_DIR/src/cli/reference.py" "$2" ;;
  build-ui) cd "$SCRIPT_DIR/garage-ui" && npm run build 2>&1;;
  rebuild-ui) cd "$SCRIPT_DIR/garage-ui" && rm -rf out node_modules/.cache && npm run build 2>&1;;
  backup)  _backup ;;
  export)  _export ;;
  quick)   _quick "$@" ;;
  builder) shift; exec ./kittybuilder "$@" ;;
  *)       echo "Usage: kitty [start|stop|restart|status|problems|briefing|build-ui|rebuild-ui|logs|ref|backup|export|quick|builder]"; exit 1 ;;
esac
