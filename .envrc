# Worktrees have no venv of their own; fall back to the main checkout's venv.
if [[ -f venv/bin/activate ]]; then
  source venv/bin/activate
elif [[ -f "$HOME/Projects/kitty/venv/bin/activate" ]]; then
  source "$HOME/Projects/kitty/venv/bin/activate"
else
  echo "WARNING: no venv found here or in ~/Projects/kitty (run: python3.12 -m venv venv)" >&2
fi
